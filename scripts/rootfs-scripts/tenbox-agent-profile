#!/bin/sh
set -eu

USER_NAME="${TENBOX_USER:-tenbox}"
USER_GROUP="${TENBOX_GROUP:-$USER_NAME}"
HOME_DIR="${TENBOX_HOME_DIR:-/home/$USER_NAME}"
FORMAT_NAME="tenbox-agent-profile"
FORMAT_VERSION="1"
SHARED_DIR="${TENBOX_SHARED_DIR:-/mnt/shared}"

usage() {
    cat >&2 <<EOF
Usage:
  tenbox-agent-profile export --agent hermes|openclaw --output /mnt/shared/name.tar.zst
  tenbox-agent-profile import --input /mnt/shared/name.tar.zst [--agent hermes|openclaw]
EOF
}

die() {
    echo "tenbox-agent-profile: $*" >&2
    exit 1
}

need_tool() {
    command -v "$1" >/dev/null 2>&1 || die "missing required tool: $1"
}

agent_path() {
    case "$1" in
        hermes) printf '%s/.hermes\n' "$HOME_DIR" ;;
        openclaw) printf '%s/.openclaw\n' "$HOME_DIR" ;;
        *) die "unsupported agent: $1" ;;
    esac
}

agent_excludes() {
    case "$1" in
        hermes)
            printf '%s\n' \
                ".hermes/logs" \
                ".hermes/image_cache" \
                ".hermes/audio_cache"
            ;;
        openclaw)
            printf '%s\n' \
                ".openclaw/cache" \
                ".openclaw/.cache" \
                ".openclaw/workspace/.cache"
            ;;
    esac
}

default_agent() {
    if [ -d "$HOME_DIR/.hermes" ] && [ ! -d "$HOME_DIR/.openclaw" ]; then
        echo hermes
    elif [ -d "$HOME_DIR/.openclaw" ] && [ ! -d "$HOME_DIR/.hermes" ]; then
        echo openclaw
    else
        die "use --agent hermes or --agent openclaw"
    fi
}

created_at() {
    date -u +"%Y-%m-%dT%H:%M:%SZ"
}

safe_output_path() {
    case "$1" in
        "$SHARED_DIR"/*) printf '%s\n' "$1" ;;
        *) die "output/input must be under $SHARED_DIR" ;;
    esac
}

parse_agent_from_manifest() {
    sed -n 's/^[[:space:]]*"agent_type":[[:space:]]*"\([^"]*\)".*/\1/p' "$1" | head -n 1
}

write_manifest() {
    agent="$1"
    manifest="$2"
    source_path="$(agent_path "$agent")"
    excludes_json=""
    while IFS= read -r item; do
        [ -n "$item" ] || continue
        if [ -n "$excludes_json" ]; then
            excludes_json="$excludes_json,"
        fi
        excludes_json="$excludes_json\"$item\""
    done <<EOF
$(agent_excludes "$agent")
EOF

    cat > "$manifest" <<EOF
{
  "format": "$FORMAT_NAME",
  "format_version": $FORMAT_VERSION,
  "agent_type": "$agent",
  "tenbox_version": "unknown",
  "created_at": "$(created_at)",
  "home": "$HOME_DIR",
  "source_path": "$source_path",
  "paths": ["files/.$agent"],
  "excluded": [$excludes_json],
  "checksums": "sha256"
}
EOF
}

build_exclude_args() {
    agent="$1"
    while IFS= read -r item; do
        [ -n "$item" ] || continue
        printf '%s\n%s\n' "--exclude" "$item"
    done <<EOF
$(agent_excludes "$agent")
EOF
}

export_profile() {
    agent="$1"
    output="$(safe_output_path "$2")"
    source_path="$(agent_path "$agent")"
    [ -d "$source_path" ] || die "Agent data is not initialized"

    need_tool tar
    need_tool zstd
    need_tool sha256sum

    tmp="$(mktemp -d)"
    trap 'rm -rf "$tmp"' EXIT INT TERM
    mkdir -p "$tmp/files"

    rel_path=".$agent"
    set -- $(build_exclude_args "$agent")
    (cd "$HOME_DIR" && tar "$@" -cf - "$rel_path") | (cd "$tmp/files" && tar -xf -)

    write_manifest "$agent" "$tmp/manifest.json"
    (cd "$tmp" && find files -type f | LC_ALL=C sort | while IFS= read -r file; do sha256sum "$file"; done > checksums.txt)

    mkdir -p "$(dirname "$output")"
    (cd "$tmp" && tar --zstd -cf "$tmp/package.tar.zst" manifest.json files checksums.txt)
    rm -f "$output"
    cp "$tmp/package.tar.zst" "$output"
    chmod 600 "$output"
    echo "$output"
}

restore_backup() {
    target="$1"
    backup="$2"
    if [ -d "$backup" ] && [ ! -e "$target" ]; then
        mv "$backup" "$target"
    fi
}

import_profile() {
    input="$(safe_output_path "$1")"
    requested_agent="$2"
    [ -f "$input" ] || die "package not found: $input"

    need_tool tar
    need_tool zstd
    need_tool sha256sum

    tmp="$(mktemp -d)"
    trap 'rm -rf "$tmp"' EXIT INT TERM
    tar --zstd -xf "$input" -C "$tmp"

    [ -f "$tmp/manifest.json" ] || die "manifest.json missing"
    [ -f "$tmp/checksums.txt" ] || die "checksums.txt missing"
    agent="$(parse_agent_from_manifest "$tmp/manifest.json")"
    [ -n "$agent" ] || die "agent_type missing in manifest"
    case "$agent" in hermes|openclaw) ;; *) die "unsupported package agent: $agent" ;; esac
    if [ -n "$requested_agent" ] && [ "$requested_agent" != "$agent" ]; then
        die "package is for $agent, not $requested_agent"
    fi

    if [ -s "$tmp/checksums.txt" ]; then
        (cd "$tmp" && sha256sum -c checksums.txt >/dev/null)
    fi
    target="$(agent_path "$agent")"
    rel_path=".$agent"
    [ -d "$tmp/files/$rel_path" ] || die "package files missing for $agent"

    backup=""
    if [ -e "$target" ]; then
        backup="$target.pre-import-$(date -u +%Y%m%d%H%M%S)"
        mv "$target" "$backup"
    fi

    if ! (cd "$tmp/files" && tar -cf - "$rel_path") | (cd "$HOME_DIR" && tar -xf -); then
        rm -rf "$target"
        restore_backup "$target" "$backup"
        die "failed to restore Agent data"
    fi
    chown -R "$USER_NAME:$USER_GROUP" "$target"
    chmod 700 "$target" 2>/dev/null || true

    if [ -n "$backup" ]; then
        echo "$backup"
    else
        echo "imported"
    fi
}

cmd="${1:-}"
[ -n "$cmd" ] || { usage; exit 2; }
shift || true

agent=""
output=""
input=""

while [ "$#" -gt 0 ]; do
    case "$1" in
        --agent) agent="${2:-}"; shift 2 ;;
        --output) output="${2:-}"; shift 2 ;;
        --input) input="${2:-}"; shift 2 ;;
        -h|--help) usage; exit 0 ;;
        *) die "unknown option: $1" ;;
    esac
done

case "$cmd" in
    export)
        [ -n "$agent" ] || agent="$(default_agent)"
        [ -n "$output" ] || die "--output is required"
        export_profile "$agent" "$output"
        ;;
    import)
        [ -n "$input" ] || die "--input is required"
        import_profile "$input" "$agent"
        ;;
    *) usage; exit 2 ;;
esac
